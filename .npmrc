strict-peer-dependencies=false
auto-install-peers=true

# Auth for publishing to the public npm registry. The token is read from the
# NPM_TOKEN environment variable at runtime (nothing secret is committed).
# Both npmjs hosts are covered since nx resolves the registry as .com.
//registry.npmjs.org/:_authToken=${NPM_TOKEN}
//registry.npmjs.com/:_authToken=${NPM_TOKEN}
